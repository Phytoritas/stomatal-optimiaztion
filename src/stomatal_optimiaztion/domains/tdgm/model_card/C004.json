        "assumptions": [
            {
                "id": "A25",
                "text": "Whole-stem growth can be represented using a Lockhart-type equation applied at the stem scale (following prior stem-level formulations).",
                "uncertain": false,
                "evidence": [
                    {
                        "page": 24,
                        "block_id": "p24_L403-406",
                        "char_span": null,
                        "snippet": "Whole-stem growth rates are predicted from the Lockhart (1965) equation... describe the growth of stem tissue..."
                    }
                ]
            },
            {
                "id": "A26",
                "text": "Stem biomass can be represented by CW = ρcS ξ H D^2 with constant stem carbon density ρcS and form factor ξ.",
                "uncertain": false,
                "evidence": [
                    {
                        "page": 24,
                        "block_id": "p24_L411-416",
                        "char_span": null,
                        "snippet": "CW = ρcS ξ H D^2 ... where ρcS is the stem carbon density ... ξ is an empirical form factor ..."
                    }
                ]
            },
            {
                "id": "A27",
                "text": "Basal diameter and height obey an allometric power law D ∝ H^a (equivalent to dS ∝ z^a used earlier).",
                "uncertain": false,
                "evidence": [
                    {
                        "page": 24,
                        "block_id": "p24_L424-426",
                        "char_span": null,
                        "snippet": "an allometric relationship between basal diameter and height (D ∝ H^a), equivalent to Eq. S.1.12."
                    }
                ]
            },
            {
                "id": "A28",
                "text": "At fixed z̃, furcation number N is time-constant, and N is non-uniform in z̃ but does not vary with time at a given z̃.",
                "uncertain": false,
                "evidence": [
                    {
                        "page": 25,
                        "block_id": "p25_L430-432",
                        "char_span": null,
                        "snippet": "N is non-uniform with regard to z̃, but constant with regards to t at a given z̃..."
                    }
                ]
            },
            {
                "id": "A29",
                "text": "Phloem thickness scales allometrically with stem diameter: dp ∝ dS^b.",
                "uncertain": false,
                "evidence": [
                    {
                        "page": 25,
                        "block_id": "p25_L434-436",
                        "char_span": null,
                        "snippet": "allometric scaling between stem diameter and phloem thickness ... dp ∝ dS^b."
                    }
                ]
            },
            {
                "id": "A30",
                "text": "Growth occurs only where (P − Γ) ≥ 0, implemented via max(P − Γ, 0) and equivalent integration bounds z̃+ to 1.",
                "uncertain": false,
                "evidence": [
                    {
                        "page": 25,
                        "block_id": "p25_L448-451",
                        "char_span": null,
                        "snippet": "discontinuities arising from the maximum operation... removed by changing the bounds of integration... where (P − Γ) ≥ 0... where P(z̃+) = Γ..."
                    }
                ]
            },
            {
                "id": "A31",
                "text": "Turgor pressure increases monotonically with z̃ (∂P/∂z̃ ≥ 0) so the active-growth region is contiguous (z̃+ ≤ z̃ ≤ 1).",
                "uncertain": false,
                "evidence": [
                    {
                        "page": 25,
                        "block_id": "p25_L451-456",
                        "char_span": null,
                        "snippet": "bounds... chosen based on the assumption that ∂P/∂z̃ ≥ 0 at any z̃... given uniform osmotic potentials..."
                    }
                ]
            },
            {
                "id": "A32",
                "text": "Uniform osmotic potential Π along the stem (as suggested by PTM results) and a linear water potential profile ψ(z̃) = ψS + (ψRc − ψS) z̃ are used to derive closed-form expressions.",
                "uncertain": false,
                "evidence": [
                    {
                        "page": 25,
                        "block_id": "p25_L456-459",
                        "char_span": null,
                        "snippet": "For a system with uniform osmotic potential and a linear water potential drop along the stem... ψ = ψS + (ψRc - ψS)∙z̃..."
                    }
                ]
            },
            {
                "id": "A33",
                "text": "Whole-stem carbon growth rate relates to whole-tree growth through the stem allocation fraction uS: ∂CW/∂t = uS G.",
                "uncertain": false,
                "evidence": [
                    {
                        "page": 26,
                        "block_id": "p26_L476-479",
                        "char_span": null,
                        "snippet": "∂CW/∂t = uS G ... where uS is the fraction of growth allocated to stems..."
                    }
                ]
            }
        ],
