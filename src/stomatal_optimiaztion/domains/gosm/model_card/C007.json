        "assumptions": [
            {
                "id": "A1",
                "text": "Alternative models are treated as instantaneous optimization problems expressed using a hydraulic cost term Theta, leading to a first-order optimality condition d/dgc [An - Theta] = 0.",
                "uncertain": false,
                "evidence": [
                    {
                        "page": 38,
                        "block_id": "p38_s7_intro_eq",
                        "char_span": null,
                        "snippet": "Hence, they solve the instantaneous maximization problem ... d/dgc [An − Θ] = 0, (S7.1)"
                    }
                ]
            },
            {
                "id": "A2",
                "text": "Each model is solved numerically such that the model-specific marginal cost of water (chi_w) equals the marginal carbon profit of water (lambda; referenced Eq. S4.11).",
                "uncertain": false,
                "evidence": [
                    {
                        "page": 39,
                        "block_id": "p39_s7_solver_rule",
                        "char_span": null,
                        "snippet": "We solve each model’s optimization numerically such that the marginal cost of water, χw ... equals the marginal carbon profit of water, λ (Eq. S4.11)."
                    }
                ]
            },
            {
                "id": "A3",
                "text": "Some models require derivatives of leaf water potential with respect to transpiration; second derivatives (d2 psiL / dE2) are computed numerically when needed.",
                "uncertain": false,
                "evidence": [
                    {
                        "page": 40,
                        "block_id": "p40_s7_sperry_second_deriv",
                        "char_span": null,
                        "snippet": "∂2ψL/∂E2 was calculated numerically."
                    },
