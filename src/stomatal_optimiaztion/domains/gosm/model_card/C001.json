        "assumptions": [
            {
                "id": "A1",
                "text": "Stem and root maintenance respiration is substrate-limited by NSC availability via σ_r(C), implemented as a Michaelis–Menten function.",
                "uncertain": false,
                "evidence": [
                    {
                        "page": 20,
                        "block_id": "p20_b1",
                        "char_span": null,
                        "snippet": "R_M = σ_r(C) R_{M,0}. (S1.3)"
                    },
                    {
                        "page": 20,
                        "block_id": "p20_b4",
                        "char_span": null,
                        "snippet": "σ_r(C) = C/(C+γ_r C_struct). (S1.4)"
                    }
                ]
            },
            {
                "id": "A2",
                "text": "Maintenance respiration is not explicitly formulated as a function of water availability (e.g., turgor/tissue water content) for simplicity.",
                "uncertain": false,
                "evidence": [
                    {
                        "page": 20,
                        "block_id": "p20_b6",
                        "char_span": null,
                        "snippet": "we do not formulate R_M as a function of water availability here for simplicity and parametrical parsimony."
                    }
                ]
            },
            {
                "id": "A3",
                "text": "Total structural biomass in carbon equivalents (C_struct) is treated as approximately constant in simulations (dC_struct/dt ≈ 0).",
                "uncertain": false,
                "evidence": [
                    {
                        "page": 20,
                        "block_id": "p20_b7",
                        "char_span": null,
                        "snippet": "we treat C_struct here as a constant in our simulations (dC_struct/dt ≈ 0)"
                    },
                    {
                        "page": 21,
                        "block_id": "p21_b6",
                        "char_span": null,
                        "snippet": "approximate C_struct as a constant, which is reasonable if simulations are short or simulated trees are mature in stature"
                    }
                ]
            },
            {
                "id": "A4",
                "text": "Whole-tree growth is modeled as sink-limited potential growth G0 multiplied by an NSC limitation function σ_g(C), also Michaelis–Menten.",
                "uncertain": false,
                "evidence": [
                    {
                        "page": 21,
                        "block_id": "p21_b3",
                        "char_span": null,
                        "snippet": "G = σ_g(C) G0. (S1.7)"
                    },
                    {
                        "page": 21,
                        "block_id": "p21_b5",
                        "char_span": null,
                        "snippet": "σ_g(C) = C/(C+γ_g C_struct). (S1.8)"
                    }
                ]
            }
        ],
